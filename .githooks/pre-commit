#!/usr/bin/env sh
set -eu

echo "ARR pre-commit: git diff --check"
git diff --cached --check

if [ -n "${PYTHON:-}" ]; then
  PYTHON_BIN="$PYTHON"
elif [ -x "_codex_runtime/tmp/venv-final-pass/Scripts/python.exe" ]; then
  PYTHON_BIN="_codex_runtime/tmp/venv-final-pass/Scripts/python.exe"
elif [ -x "_codex_runtime/tmp/venv-arr/Scripts/python.exe" ]; then
  PYTHON_BIN="_codex_runtime/tmp/venv-arr/Scripts/python.exe"
else
  PYTHON_BIN="python"
fi

echo "ARR pre-commit: compileall"
"$PYTHON_BIN" -m compileall -q conftest.py services tests

if ! command -v node >/dev/null 2>&1; then
  echo "ARR pre-commit: node no esta disponible para validar panel.js" >&2
  exit 1
fi

echo "ARR pre-commit: node --check panel.js"
node --check services/media-panel/media_panel/web/static/js/panel.js

echo "ARR pre-commit: contratos rapidos"
"$PYTHON_BIN" -m pytest -q \
  tests/test_project_governance.py \
  tests/test_pytest_contracts.py \
  services/arr-orchestrator/tests/test_arr_blackbox.py \
  services/arr-orchestrator/tests/test_arr_follow.py \
  services/buscador-puente-arr/tests/test_arr_trace.py
